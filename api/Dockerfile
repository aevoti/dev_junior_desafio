FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY . .
RUN dotnet restore PokemonTrainingCenter.sln
RUN dotnet publish src/PokemonTrainingCenter.Api/PokemonTrainingCenter.Api.csproj -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
COPY --from=build /app .
EXPOSE 8080
ENTRYPOINT ["dotnet", "PokemonTrainingCenter.Api.dll"]
